{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "./dist/cjs",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
        "emitDeclarationOnly": false,
        "jsx": "react-jsx"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "tests"
    ]
}