{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist/types",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["tests", "**/*.test.ts"]
}