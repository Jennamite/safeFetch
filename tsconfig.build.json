{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
  },
  "include": ["src/index.ts"],
  "exclude": ["tests", "**/*.test.ts"]
}