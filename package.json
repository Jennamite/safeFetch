{
  "name": "@jennamite/safe-fetch",
  "version": "1.0.5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jennamite/safeFetch.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "shx rm -rf dist",
    "build": "npm run clean && tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@vitest/browser": "^4.1.2",
    "jsdom": "^29.0.1",
    "node-fetch": "^3.3.2",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "fetch",
    "http",
    "client",
    "typescript",
    "caching",
    "batching",
    "retry"
  ],
  "author": "Jennamite",
  "license": "MIT",
  "peerDependencies": {
    "node-fetch": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "node-fetch": {
      "optional": true
    }
  }
}